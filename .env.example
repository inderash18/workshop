# ==========================================
# AI Next Gen - Environment Configuration
# ==========================================

# ------------------------------------------
# FRONTEND CONFIGURATION
# ------------------------------------------
# Point this to your Render backend URL (or localhost for development)
VITE_API_URL="http://localhost:5000"
NEXT_PUBLIC_API_URL="http://localhost:5000"
REACT_APP_API_URL="http://localhost:5000"
API_URL="http://localhost:5000"

# ------------------------------------------
# BACKEND CONFIGURATION
# ------------------------------------------
# MongoDB Atlas Connection URI
# ⚠️  Set this in your Render dashboard / .env file — never hardcode secrets
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net"

# Secure Cookies (Set to True for production HTTPS, False for local HTTP testing)
SESSION_COOKIE_SECURE="True"
SESSION_COOKIE_SAMESITE="Lax"

# Security & Password Hashing
SECRET_KEY="your-production-secret-key-min-32-chars-random"
PASSWORD_SALT="your-production-password-salt-min-16-chars"

# CORS Configurations (Comma separated list of allowed domains)
ALLOWED_ORIGINS="https://your-frontend-domain.vercel.app,http://localhost:5000,http://127.0.0.1:5000"

# Fallback Settings
ALLOW_DB_FALLBACK="False" # Set to False in production to prevent silent data loss if MongoDB fails
FLASK_ENV="production"
ENV="production"
