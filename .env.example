# ==========================================
# AI Next Gen - Environment Configuration
# ==========================================

# ------------------------------------------
# FRONTEND CONFIGURATION (Vercel)
# ------------------------------------------
# Point this to your Render backend URL.
VITE_API_URL="https://workshop-0mk8.onrender.com"
NEXT_PUBLIC_API_URL="https://workshop-0mk8.onrender.com"
REACT_APP_API_URL="https://workshop-0mk8.onrender.com"
API_URL="https://workshop-0mk8.onrender.com"

# ------------------------------------------
# BACKEND CONFIGURATION (Render)
# ------------------------------------------
# MongoDB Atlas Connection URI
MONGODB_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/ai_next_gen?retryWrites=true&w=majority"

# Secure Cookies (Set to True for Render production, False for local HTTP testing)
SESSION_COOKIE_SECURE="True"
SESSION_COOKIE_SAMESITE="None"

# Security & Password Hashing
SECRET_KEY="your-production-secret-key"
PASSWORD_SALT="your-production-password-salt"

# CORS Configurations (Comma separated list of allowed domains)
ALLOWED_ORIGINS="https://workshop-eight-iota.vercel.app,http://localhost:5000,http://127.0.0.1:5000"

# Fallback Settings
ALLOW_DB_FALLBACK="False" # Set to False in production to prevent silent data loss if MongoDB Atlas fails
FLASK_ENV="production"
ENV="production"

